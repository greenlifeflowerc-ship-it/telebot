# ---------------------------------------------------------------------------
# Copy this file to ".env" for local development, or set these as environment
# variables in the Render dashboard.
#
# These are PLACEHOLDERS only. Replace them with your own values.
# NEVER commit a real .env file or real secrets to git.
# ---------------------------------------------------------------------------

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:your-bot-token-from-botfather

# Secret used in the webhook path: {PUBLIC_URL}/webhook/{WEBHOOK_SECRET}
# Allowed characters ONLY: A-Z a-z 0-9 _ -
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=replace-with-a-long-random-string

# Public HTTPS URL of this service. OPTIONAL on Render — it is read from
# RENDER_EXTERNAL_URL automatically. Set PUBLIC_URL only as a fallback
# (other hosts, or a tunnel like ngrok). No trailing slash.
PUBLIC_URL=https://your-app.onrender.com

# Set to "true" to enable the debug-only /webhook-info endpoint. Keep "false"
# (or unset) in production.
DEBUG=false

# No video compression — RECOMMENDED (this is the whole point: speed).
# When "true": the bot NEVER re-encodes video (no libx264 / CRF / scale). It
# downloads the original quality and only fixes the container to MP4 with a fast
# stream copy (ffmpeg -c copy). Originals over the Telegram limit are rejected,
# not shrunk. Set "false" only if you want to allow the opt-in re-encode below.
NO_VIDEO_COMPRESSION=true

# Never re-encode by default — RECOMMENDED. Kept for the opt-in fallback: a
# re-encode can only ever run when BOTH this is "false" AND
# NO_VIDEO_COMPRESSION is "false".
NO_REENCODE_BY_DEFAULT=true

# Fast mode — RECOMMENDED for slow CPUs (Render Free).
# When "true": an already-MP4 file is sent directly (no ffmpeg at all).
# When "false": it is fast stream-copy remuxed (+faststart) instead.
FAST_MODE=true

# Send the video only once via sendVideo (recommended). Set "true" only if you
# ALSO want a document copy of every video (not recommended).
SEND_VIDEO_AS_FILE_COPY=false

# Browser impersonation for PUBLIC content — RECOMMENDED.
# When "true": yt-dlp makes its requests look like a real browser (TLS/UA) so
# platforms' anti-bot layers don't block legitimate PUBLIC downloads (e.g. a
# TikTok whose in-app "download" button is off). This is fingerprint matching,
# NOT cookies / login / DRM / geo bypass. Needs the curl_cffi package (in
# requirements.txt); if it's missing the bot just skips impersonation.
IMPERSONATE=true

# Optional. Only affects the (rare, opt-in) re-encode fallback height cap.
# LOW_RESOURCE_MODE=true

# NOTE: PORT and RENDER_EXTERNAL_URL are injected by Render automatically —
# do not set them yourself.
